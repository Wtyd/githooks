{
    "name": "wtyd/githooks",
    "description": "Manage git hooks in a simple and sophisticated way.",
    "keywords": [
        "git",
        "githooks",
        "hooks",
        "precommit",
        "pre-commit",
        "commit",
        "qa",
        "console",
        "cli"
    ],
    "type": "library",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/Wtyd/githooks/issues",
        "source": "https://github.com/Wtyd/githooks"
    },
    "authors": [
        {
            "name": "Jorge Lilao",
            "email": "jorgelilaoc@gmail.com"
        },
        {
            "name": "Pablo Lilao",
            "email": "pablolilao@protonmail.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.19",
        "intonate/tinker-zero": "1.*",
        "laravel-zero/framework": "8.* | 9.* | 10.* | 11.* | 12.*",
        "laravel-zero/phar-updater": "^1.0.6",
        "mikey179/vfsstream": "^1.6",
        "mockery/mockery": "^1.3",
        "php-parallel-lint/php-parallel-lint": "^1.2",
        "phpmd/phpmd": "^2.9",
        "phpstan/phpstan": "^1.4 | ^2.0",
        "phpunit/php-code-coverage": "^9.0 | ^10.0",
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.5",
        "symfony/yaml": "^5.0 | 6.*",
        "vimeo/psalm": "^5.0 | ^6.0"
    },
    "autoload": {
        "psr-4": {
            "Wtyd\\GitHooks\\App\\": "app/",
            "Wtyd\\GitHooks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "TestsDir\\": "testsDir/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "builds/githooks"
    ]
}
